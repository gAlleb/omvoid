#!/bin/bash

export OMVOID_PATH=$HOME/.local/share/omvoid
export PATH=$OMVOID_PATH/bin/:$PATH

set -e  

FIRST_RUN_MODE=~/.local/state/omvoid/first-run.mode

if [[ -f "$FIRST_RUN_MODE" ]]; then
  rm -f "$FIRST_RUN_MODE"
  sed -i '/^exec-once=omvoid-cmd-first-run\s*$/d' ~/.config/mango/conf/autostart.conf
  omvoid-font-set "CaskaydiaMono Nerd Font"
  omvoid-theme-set rain-world
  #$OMVOID_PATH/install/first-run/battery-monitor.sh
  #$OMVOID_PATH/install/first-run/firewall.sh
fi
