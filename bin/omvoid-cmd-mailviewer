#!/usr/bin/env python3
import sys, os, email, tempfile, subprocess
from email import policy

def main():
    msg = email.message_from_bytes(sys.stdin.buffer.read(), policy=policy.default)

    html = plain = None
    for part in msg.walk():
        ct = part.get_content_type()
        if ct == 'text/html' and html is None:
            try: html = part.get_content()
            except Exception: pass
        elif ct == 'text/plain' and plain is None:
            try: plain = part.get_content()
            except Exception: pass

    if html is None:
        if plain is None: sys.exit(0)
        import html as h
        html = '<meta charset="utf-8"><pre style="white-space:pre-wrap">%s</pre>' % h.escape(plain)

    tmp = tempfile.mkdtemp(prefix='mailview-')
    for part in msg.walk():
        if part.get_content_type().startswith('image/'):
            cid = part.get('Content-ID')
            if not cid: continue
            cid = cid.strip('<>')
            fn = os.path.join(tmp, cid.replace('/', '_') + '.' + part.get_content_type().split('/')[-1])
            try:
                with open(fn, 'wb') as f: f.write(part.get_content())
                html = html.replace('cid:' + cid, 'file://' + fn)
            except Exception: pass

    page = os.path.join(tmp, 'message.html')
    with open(page, 'w', encoding='utf-8') as f: f.write(html)
    subprocess.Popen(['setsid', '-f', os.environ.get('BROWSER', 'xdg-open'), page],
                     stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

main()
